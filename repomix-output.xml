            </td>
            <td class="py-4 px-6 text-right font-bold text-emerald-600 font-mono">
              ${{ vta.total_venta | number:'1.2-2' }}
            </td>
            <td class="py-4 px-6 text-xs text-gray-500">
              {{ vta.fecha | date:'medium' }}
            </td>
          </tr>
          <tr *ngIf="historialVentas.length === 0 && !isLoading">
            <td colspan="6" class="py-10 text-center text-gray-400">
              No hay registradas ventas comerciales de platos en el historial.
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

</div>
