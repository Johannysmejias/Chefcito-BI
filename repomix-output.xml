<div class="p-6 max-w-6xl mx-auto">
  <!-- Cabecera del Dashboard -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
    <div>
      <h2 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
        📊 Dashboard General de Stock & Historial
      </h2>
      <p class="text-sm text-gray-500">
        Supervisión unificada del inventario completo, logística interna de cocina y registro de ventas.
      </p>
    </div>
    <button (click)="cargarDashboard()" [disabled]="isLoading"
      class="px-4 py-2 text-sm bg-indigo-50 border border-indigo-200 text-indigo-700 font-medium rounded-lg hover:bg-indigo-100 transition duration-150 flex items-center gap-2">
      <span *ngIf="isLoading" class="animate-spin">🔄</span>
      <span>Sincronizar Datos</span>
    </button>
  </div>

  <div *ngIf="errorMessage" class="mb-4 p-4 bg-rose-50 border border-rose-200 text-rose-800 rounded-lg flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span>❌</span>
      <span>{{ errorMessage }}</span>
    </div>
    <button (click)="errorMessage = ''" class="text-rose-500 hover:text-rose-700">×</button>
  </div>

  <!-- PESTAÑAS DEL DASHBOARD -->
  <div class="flex border-b border-gray-200 mb-6 gap-2">
    <button (click)="setSubTab('inventario')"
      [ngClass]="{
        'border-indigo-600 text-indigo-600 font-bold bg-indigo-50/50': activeSubTab === 'inventario',
        'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 font-medium': activeSubTab !== 'inventario'
      }"
      class="py-3 px-5 border-b-2 text-sm transition duration-150 flex items-center gap-2 rounded-t-lg">
      📦 Inventario General
    </button>

    <button (click)="setSubTab('produccion')"
      [ngClass]="{
        'border-indigo-600 text-indigo-600 font-bold bg-indigo-50/50': activeSubTab === 'produccion',
        'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 font-medium': activeSubTab !== 'produccion'
      }"
      class="py-3 px-5 border-b-2 text-sm transition duration-150 flex items-center gap-2 rounded-t-lg">
      👩‍🍳 Historial de Producción
    </button>

    <button (click)="setSubTab('ventas')"
      [ngClass]="{
        'border-indigo-600 text-indigo-600 font-bold bg-indigo-50/50': activeSubTab === 'ventas',
        'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300 font-medium': activeSubTab !== 'ventas'
      }"
      class="py-3 px-5 border-b-2 text-sm transition duration-150 flex items-center gap-2 rounded-t-lg">
      💰 Historial de Ventas
    </button>
  </div>

  <!-- SECCIÓN 1: INVENTARIO COMPLETO -->
  <div *ngIf="activeSubTab === 'inventario'" class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-gray-50/70 border-b border-gray-200 text-gray-500 text-xs font-semibold uppercase tracking-wider">
            <th class="py-4 px-6">ID</th>
            <th class="py-4 px-6">Artículo</th>
            <th class="py-4 px-6">Tipo</th>
            <th class="py-4 px-6 text-right">Stock Actual</th>
            <th class="py-4 px-6 text-right">Stock Mínimo</th>
            <th class="py-4 px-6 text-right">Precio Venta</th>
            <th class="py-4 px-6 text-center">Estado</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 text-sm">
          <tr *ngFor="let item of inventarioCompleto" class="hover:bg-gray-50/50 transition">
            <td class="py-4 px-6 font-mono text-xs text-gray-400">#{{ item.id }}</td>
            <td class="py-4 px-6">
              <span class="font-bold text-gray-800">{{ item.nombre }}</span>
              <span class="block text-xs text-gray-400">Medida: {{ item.unidad_medida }}</span>
            </td>
            <td class="py-4 px-6">
              <span class="px-2.5 py-1 rounded text-xs font-semibold tracking-wide uppercase" 
                [ngClass]="getBadgeClase(item.tipo)">
                {{ item.tipo }}
              </span>
            </td>
            <td class="py-4 px-6 text-right font-semibold"
              [ngClass]="{'text-rose-600': item.stock_actual < item.stock_minimo, 'text-gray-700': item.stock_actual >= item.stock_minimo}">
              {{ item.stock_actual | number:'1.1-3' }}
            </td>
            <td class="py-4 px-6 text-right font-mono text-gray-500">
              {{ item.stock_minimo | number:'1.1-3' }}
            </td>
            <td class="py-4 px-6 text-right font-mono text-gray-600 font-medium">
              {{ item.precio_venta ? ('$' + (item.precio_venta | number:'1.2-2')) : '-' }}
            </td>
            <td class="py-4 px-6 text-center">
              <span *ngIf="item.stock_actual < item.stock_minimo" 
                class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-rose-50 text-rose-700 border border-rose-100">
                🚨 Bajo Mínimo
              </span>
              <span *ngIf="item.stock_actual >= item.stock_minimo" 
                class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-100">
                ✔️ Óptimo
              </span>
            </td>
          </tr>
          <tr *ngIf="inventarioCompleto.length === 0 && !isLoading">
            <td colspan="7" class="py-10 text-center text-gray-400">Catálogo vacío.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- SECCIÓN 2: HISTORIAL DE PRODUCCIÓN -->
  <div *ngIf="activeSubTab === 'produccion'" class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-gray-50/70 border-b border-gray-200 text-gray-500 text-xs font-semibold uppercase tracking-wider">
            <th class="py-4 px-6">ID Reg</th>
            <th class="py-4 px-6">Artículo Semi-Elaborado</th>
            <th class="py-4 px-6 text-right">Cantidad Cocinada</th>
            <th class="py-4 px-6">Fecha y Hora</th>
            <th class="py-4 px-6">Estado Transacción</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 text-sm text-gray-700">
          <tr *ngFor="let prod of historialProduccion" class="hover:bg-gray-50/50 transition">
            <td class="py-4 px-6 font-mono text-xs">#{{ prod.id }}</td>
            <td class="py-4 px-6">
              <span class="font-semibold text-gray-800">{{ prod.semi_nombre }}</span>
              <span class="block text-xs text-gray-400">ID Articulo #{{ prod.semi_id }}</span>
            </td>
            <td class="py-4 px-6 text-right font-bold text-indigo-600 font-mono">
              +{{ prod.cantidad }} unidades
            </td>
            <td class="py-4 px-6 text-xs text-gray-500">
              {{ prod.fecha | date:'medium' }}
            </td>
            <td class="py-4 px-6">
              <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700 border border-blue-100">
                ⛓️ SQL Commit
              </span>
            </td>
          </tr>
          <tr *ngIf="historialProduccion.length === 0 && !isLoading">
            <td colspan="5" class="py-10 text-center text-gray-400">
              No se han registrado producciones de cocina en el historial.
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- SECCIÓN 3: HISTORIAL DE VENTAS -->
  <div *ngIf="activeSubTab === 'ventas'" class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-gray-50/70 border-b border-gray-200 text-gray-500 text-xs font-semibold uppercase tracking-wider">
            <th class="py-4 px-6">Reg ID</th>
            <th class="py-4 px-6">Nro. Venta</th>
            <th class="py-4 px-6">Plato Vendido</th>
            <th class="py-4 px-6 text-right">Cantidad</th>
            <th class="py-4 px-6 text-right">Valor Factura</th>
            <th class="py-4 px-6">Fecha Registro</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 text-sm text-gray-700">
          <tr *ngFor="let vta of historialVentas" class="hover:bg-gray-50/50 transition">
            <td class="py-4 px-6 font-mono text-xs">#{{ vta.id }}</td>
            <td class="py-4 px-6 font-semibold text-gray-500 font-mono">TICKET #{{ vta.venta_id }}</td>
            <td class="py-4 px-6 font-semibold text-gray-800">
