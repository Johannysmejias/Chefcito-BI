<file path="frontend/src/app/components/produccion-cocina/produccion-cocina.component.html">
<div class="p-6 max-w-6xl mx-auto">
  <!-- Encabezado de Cocina -->
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
    <div>
      <h2 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
        🍳 To-Do List de Producción (Cocina)
      </h2>
      <p class="text-sm text-gray-500">
        Muestra los artículos SEMI-ELABORADOS con stock crítico por debajo del mínimo normativo.
      </p>
    </div>
    <button (click)="cargarPendientesCocina()" [disabled]="isLoading"
      class="px-4 py-2 text-sm bg-indigo-50 border border-indigo-200 text-indigo-700 font-medium rounded-lg hover:bg-indigo-100 transition duration-150 flex items-center gap-2">
      <span *ngIf="isLoading" class="animate-spin">🔄</span>
      <span>Actualizar Cocina</span>
    </button>
  </div>

  <!-- Mensajes de Estado en Pantalle -->
  <div *ngIf="successMessage" class="mb-4 p-4 bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-lg flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span>✅</span>
      <span>{{ successMessage }}</span>
    </div>
    <button (click)="successMessage = ''" class="text-emerald-500 hover:text-emerald-700">❌</button>
  </div>

  <div *ngIf="errorMessage" class="mb-4 p-4 bg-rose-50 border border-rose-200 text-rose-800 rounded-lg flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span>❌</span>
      <span>{{ errorMessage }}</span>
    </div>
    <button (click)="errorMessage = ''" class="text-rose-500 hover:text-rose-700">×</button>
  </div>

  <!-- Vista Vacía -->
  <div *ngIf="!isLoading && articulosBajos.length === 0"
    class="bg-emerald-50 border border-emerald-100 rounded-xl p-8 text-center text-emerald-800 flex flex-col items-center gap-2">
    <span class="text-4xl">🍕</span>
    <h3 class="font-semibold text-lg">¡Cocina al día!</h3>
    <p class="text-sm max-w-md text-emerald-600">
      Todos los productos semi-elaborados tienen suficiente inventario para cubrir el stock mínimo requerido. No hay tareas de producción pendientes.
    </p>
  </div>

  <!-- Lista de Artículos a Producir -->
  <div *ngIf="articulosBajos.length > 0" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <div *ngFor="let art of articulosBajos"
      class="bg-white border border-rose-100 shadow-sm rounded-xl p-5 hover:shadow-md transition duration-200 relative flex flex-col justify-between">

      <!-- Icono de Alerta de Escasez -->
      <div class="absolute top-4 right-4 bg-amber-50 text-amber-700 px-2.5 py-1 rounded-full text-xs font-semibold flex items-center gap-1 border border-amber-200">
        <span>⚠️ Fallante</span>
      </div>

      <div>
        <h3 class="text-lg font-bold text-gray-800 mb-1 pr-16">{{ art.nombre }}</h3>
        <p class="text-xs text-gray-400 uppercase tracking-wider mb-4">Código Art. #{{ art.id }}</p>

        <!-- Estado de Stock Comparativo -->
        <div class="bg-gray-50 rounded-lg p-3 mb-4 space-y-2">
          <div class="flex justify-between text-sm">
            <span class="text-gray-500">Stock Actual:</span>
            <span class="font-medium text-rose-600">{{ art.stock_actual }} {{ art.unidad_medida }}</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-gray-500">Mínimo Necesario:</span>
            <span class="font-medium text-gray-700">{{ art.stock_minimo }} {{ art.unidad_medida }}</span>
          </div>

          <!-- Progreso visual simple -->
          <div class="w-full bg-gray-200 rounded-full h-1.5 mt-2">
            <div class="bg-rose-500 h-1.5 rounded-full"
              [style.width.%]="(art.stock_actual / art.stock_minimo) * 100 > 100 ? 100 : (art.stock_actual / art.stock_minimo) * 100">
            </div>
          </div>
        </div>

        <!-- Mensaje Informativo de Alerta Permanente -->
        <div class="text-xs text-amber-700 bg-amber-50 rounded p-2 mb-4 border border-amber-100 flex items-start gap-1">
          <span class="text-sm leading-none">⚠️</span>
          <span>Faltan <strong>{{ (art.stock_minimo - art.stock_actual) | number:'1.1-3' }} {{ art.unidad_medida }}</strong> para satisfacer el stock mínimo de contingencia. El ítem permanecerá en cocina hasta alcanzar ese umbral.</span>
        </div>
      </div>

      <!-- Acciones de Registro -->
      <button (click)="abrirModalProduccion(art)"
        class="w-full py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg shadow-sm hover:shadow transition duration-150 flex items-center justify-center gap-2">
        <span>👩‍🍳 Marcar como hecho</span>
      </button>
    </div>
  </div>

  <!-- MODAL DE CONFIRMACIÓN DE PRODUCCIÓN -->
  <div *ngIf="showModal" class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-xl border border-gray-100 max-w-md w-full p-6 animate-in fade-in zoom-in duration-150">
      <div class="flex justify-between items-start mb-4">
        <h3 class="text-lg font-bold text-gray-800">🎯 Registrar Producción</h3>
        <button (click)="cerrarModal()" class="text-gray-400 hover:text-gray-600 text-xl font-bold leading-none">&times;</button>
      </div>

      <div class="mb-4" *ngIf="selectedArticulo">
        <p class="text-sm text-gray-600 mb-3">
          Ingrese la cantidad producida de <strong>{{ selectedArticulo.nombre }}</strong>. Los ingredientes correspondientes del catálogo (BOM) se consumirán y descontarán del stock automáticamente.
        </p>

        <label class="block text-xs font-bold text-gray-500 uppercase tracking-wide mb-1">
          Cantidad Producida ({{ selectedArticulo.unidad_medida }})
        </label>
        <input type="number" [(ngModel)]="cantidadAProducir" min="1" step="1"
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-gray-800 font-medium">
      </div>

      <!-- Footer del Modal -->
      <div class="flex justify-end gap-3 mt-6">
        <button (click)="cerrarModal()" [disabled]="isLoading"
          class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-semibold text-gray-600 hover:bg-gray-50 transition duration-150">
          Cancelar
        </button>
        <button (click)="confirmarProduccion()" [disabled]="isLoading"
          class="px-5 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg text-sm font-semibold shadow-sm transition duration-150 flex items-center gap-1">
          <span *ngIf="isLoading" class="animate-spin">🔄</span>
          <span>Confirmar Producción</span>
        </button>
      </div>
    </div>
  </div>
</div>
